{
	"name": "vectab",
	"version": "0.1.0",
	"description": "Markdown for Musicians – converts .vtab files into print-ready SVGs",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"build:web": "bun build src/browser.ts --outfile public/vectab.js --target browser --minify",
		"dev": "tsc --watch",
		"lint": "biome check .",
		"lint:fix": "biome check . --fix",
		"test": "bun test"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/bun": "^1.2.2",
		"typescript": "^5.0.0"
	},
	"engines": {
		"bun": "1.2.2",
		"node": "22.14.0"
	}
}
