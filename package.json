{
  "name": "vectab",
  "version": "0.1.0",
  "description": "Convert ASCII guitar tabs and chord charts to beautiful SVG sheets for musicians",
  "keywords": [
    "chord",
    "sheet",
    "music",
    "vtab",
    "guitar",
    "tab",
    "svg",
    "ascii"
  ],
  "homepage": "https://josephcheng.me/vectab/",
  "repository": {
    "type": "git",
    "url": "https://github.com/indiejoseph/vectab.git"
  },
  "license": "MIT",
  "author": "Joseph Cheng <iam@josephcheng.com>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:web": "bun build src/browser.ts --outfile docs/vectab.js --target browser --minify",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "^1.2.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": "1.2.2",
    "node": "22.14.0"
  }
}